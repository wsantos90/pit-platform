{
  "manifest_version": 3,
  "name": "PIT Collect",
  "version": "1.1.0",
  "description": "Coleta partidas EA Sports para campeonatos PIT usando cookies do browser local.",
  "permissions": [
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "*://*.ea.com/*",
    "https://pit-platform.vercel.app/*",
    "http://localhost/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://pit-platform.vercel.app/*",
      "http://localhost/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PIT Collect"
  }
}
