COOKIE_SERVICE_SECRET=trocar-por-secret-forte
COOKIE_SERVICE_DOMAIN=cookie.menteembeta.com.br

# 0 = desabilitado (renovacao gerenciada pelo GitHub Actions)
# 15-30 = renovacao automatica pelo Puppeteer local (requer proxy residencial)
COOKIE_RENEW_INTERVAL_MINUTES=0
COOKIE_RENEW_CRON=
COOKIE_STORAGE_DRIVER=file
AKAMAI_COOKIE_MAX_AGE_MINUTES=30
AKAMAI_COOKIE_TTL_MINUTES=30
# Timeout maior: estrategia visita multiplas paginas (homepage + API) — minimo recomendado 60s
PUPPETEER_TIMEOUT_MS=60000
PUPPETEER_MAX_ATTEMPTS=2
PUPPETEER_DISABLE_DEV_SHM=true
# Proxy residencial (fallback se GitHub Actions for bloqueado): http://user:pass@host:port
PUPPETEER_PROXY_URL=
# IMPORTANTE: usar sempre deploy-stack.sh para deploy. Nao fazer "source .env.stack" direto
# pois o shell interpreta o "&" na URL como operador de background, zerando a variavel.
EA_COOKIE_TARGET_URL=https://proclubs.ea.com/api/fc/clubs/matches?platform=common-gen5&clubIds=1499996&maxResultCount=20&matchType=friendlyMatch
EA_COOKIE_BOOTSTRAP_URL=https://proclubs.ea.com

BROWSERLESS_BASE_URL=http://browserless:3000
BROWSERLESS_TOKEN=
BROWSERLESS_FALLBACK_URL=
# ATENCAO: so habilitar se browserless realmente estiver rodando sem token (stack local)
# Se nao tiver browserless, deixar false para nao tentar fallback em servico inexistente
BROWSERLESS_ALLOW_NO_TOKEN=false
BROWSERLESS_STEALTH=true
BROWSERLESS_BLOCK_ADS=false
BROWSERLESS_TIMEOUT_MS=30000

LOG_LEVEL=info
LOG_RETENTION_DAYS=7
LOG_MAX_SIZE=10m

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
AKAMAI_COOKIES_TABLE=akamai_cookies
