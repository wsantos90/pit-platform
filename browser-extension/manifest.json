{
  "manifest_version": 3,
  "name": "PIT Collect",
  "version": "1.1.0",
  "description": "Coleta partidas EA Sports e sincroniza cookies do browser local para o PIT.",
  "permissions": [
    "cookies",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "*://*.ea.com/*",
    "https://pit.gg/*",
    "https://*.vercel.app/*",
    "https://pit-platform.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://pit.gg/*",
      "https://*.vercel.app/*",
      "https://pit-platform.vercel.app/*",
      "http://localhost:3000/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "PIT Collect 1.1.0",
    "default_popup": "popup.html"
  }
}
